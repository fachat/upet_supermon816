	

&mon_install4_xl 
	.xl
	.(
monentry	=MONBASE+0
monceprocess	=MONBASE+3
moninput	=MONBASE+6

a_vecexit	=MONBASE+9+1
a_teststp	=MONBASE+12+1
a_putcha	=MONBASE+15+1
a_getcha	=MONBASE+18+1

	lda #MONBANK
	sta BANK

	ldx #0
mvloop	lda MOVE,x
	sta MONCOMP,x
	inx
	cpx #MOVEND-MOVE
	bcc mvloop

	; link 
	ldx #monvecexit	
	stx a_vecexit
	ldx #monteststp
	stx a_teststp
	ldx #monputcha
	stx a_putcha
	ldx #mongetcha
	stx a_getcha

	lda #MAP_BAS
	sta BANK
	rts
	.)
	.xs

