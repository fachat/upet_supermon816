	

&mon_install4_xl 
	.(
monentry	=MONBASE+0
monceprocess	=MONBASE+3

a_vecexit	=MONBASE+7
a_teststp	=MONBASE+10
a_putcha	=MONBASE+13

	lda #MONBANK
	sta BANK

;	; load monitor into memory
