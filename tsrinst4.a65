	

&mon_install4_xl 
	.xl
	.(
monentry	=MONBASE+0
monceprocess	=MONBASE+3

a_vecexit	=MONBASE+7
a_teststp	=MONBASE+10
a_putcha	=MONBASE+13

	lda #MONBANK
	sta BANK

	ldx #0
mvloop	lda MOVE,x
	sta MONCOMP,x
	inx
	cpx #MOVEND-MOVE
	bcc mvloop

	; link 
	ldx #monvecexit	
	stx a_vecexit
	ldx #monteststp
	stx a_teststp
	ldx #monputcha
	stx a_putcha

	lda #MAP_BAS
	sta BANK
	rts
	.)
	.xs

